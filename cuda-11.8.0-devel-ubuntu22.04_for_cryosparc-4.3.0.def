BootStrap: docker
From: nvidia/cuda:11.8.0-devel-ubuntu22.04

%environment
  # TODO edit the next two lines with your proxy addresss if compute nodes need it for internet connectivity
  export http_proxy=http://10.72.8.25:8080
  export https_proxy=http://10.72.8.25:8080

  export no_proxy=localhost,127.0.0.0/8
  export PATH=/cryosparc_master/bin:$PATH
  export PATH=/cryosparc_worker/bin:$PATH

%post
  #Post setup, runs inside the image
  # TODO change TZ to your time zone
  ln -snf /usr/share/zoneinfo/America/Chicago /etc/localtime && echo America/Chicago > /etc/timezone

  apt-get update
  apt-get upgrade -y
  apt-get install -y --no-install-recommends tzdata locales gnupg2 openssh-server openssh-client ssh-askpass lbzip2 zip

  # Configure default locale
  echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
  locale-gen en_US.utf8
  /usr/sbin/update-locale LANG=en_US.UTF-8
  export LANG="en_US.UTF-8"
  export LC_COLLATE="en_US.UTF-8"
  export LC_CTYPE="en_US.UTF-8"
  export LC_MESSAGES="en_US.UTF-8"
  export LC_MONETARY="en_US.UTF-8"
  export LC_NUMERIC="en_US.UTF-8"
  export LC_TIME="en_US.UTF-8"
  export LC_ALL="en_US.UTF-8"

  # system update
  apt-get update -y
  apt-get upgrade -y
  
  # install other import packages
  apt-get install -y software-properties-common wget curl less jq iputils-ping
  apt-get install -y nvidia-driver-535 nvidia-dkms-535

  ### gcc compiler is required for development using the cuda toolkit. to verify the version of gcc install enter
  gcc --version
  
  # Finally, to verify the installation, check
  nvcc -V
  nvcc --list-gpu-code
