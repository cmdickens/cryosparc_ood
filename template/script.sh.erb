#!/usr/bin/env bash

nodename=${HOSTNAME}.cluster
singularity_image='cryosparc_standalone_w-master-worker-06092022.sif'

module purge
echo JOBID: $SLURM_JOBID

if [[ $(echo <%= context.cryosparc_license_id %> | grep -c '[[:alnum:]]\{8\}-[[:alnum:]]\{4\}-[[:alnum:]]\{4\}-[[:alnum:]]\{4\}-[[:alnum:]]\{12\}') == 1 ]]; then
 echo "License format correct"
else
 echo "License format incorrect"
 scancel $SLURM_JOBID
fi

if [ ! -d "$SCRATCH/.cryosparc_hprc/cryosparc_license" ]; then
    mkdir -p "$SCRATCH/.cryosparc_hprc/cryosparc_license"
fi

echo <%= context.cryosparc_license_id %> > $SCRATCH/.cryosparc_hprc/cryosparc_license/license_id


# check if directory $SCRATCH/.cryosparc_hprc/.cryosparc_database exists
if [ ! -d "$SCRATCH/.cryosparc_hprc/cryosparc_database" ]; then
    tar xzf /sw/hprc/sw/containers/cryosparc/cryosparc_database.tar.gz -C $SCRATCH/.cryosparc_hprc/
fi

# check if directory $SCRATCH/.cryosparc_hprc/.cryosparc_master exists
if [ ! -d "$SCRATCH/.cryosparc_hprc/cryosparc_master" ]; then
    tar xzf /sw/hprc/sw/containers/cryosparc/cryosparc_master-run.tar.gz -C $SCRATCH/.cryosparc_hprc/
fi

# create directory $SCRATCH/.cryosparc_hprc/.cryosparc_cache if it doesn't exist
if [ ! -d "$SCRATCH/.cryosparc_hprc/cryosparc_cache" ]; then
    mkdir -p "$SCRATCH/.cryosparc_hprc/cryosparc_cache"
fi

<%- if context.node_type =~ /CPU/ -%>
  usegpu="--nogpu"
  echo "=== CPU node type selected; no GPUs will be available"
  <%- else -%>
  usegpu="--gpus $CUDA_VISIBLE_DEVICES"
  echo CUDA_VISIBLE_DEVICES: $CUDA_VISIBLE_DEVICES
  echo SLURM_JOB_GPUS: $SLURM_JOB_GPUS
<%- end -%>

# bind group directory if provided in form and if exists
<%- if context.group_dir.blank? -%>
    echo "group directory blank: <%= context.group_dir %>"
    group_dir=''
<%- else -%>
    if [ -d <%= context.group_dir %> ]; then
        <%- if context.group_dir =~ /\/scratch\/group/ -%>
            # for /scratch/group/*
            echo "directory found: <%= context.group_dir %>"
            group_dir="-B /scratch/group:/scratch/group"
        <%- else -%>
            # for /junjiez
            group_dir="-B <%= context.group_dir %>:<%= context.group_dir %>"
        <%- end -%>
    else
        echo "directory not found: <%= context.group_dir %>"
        group_dir=''
    fi
<%- end -%>

# set ssdpath and ssdquota based on user selection for ssd_path checkbox in form.yml.erb
<%- if context.ssd_path.to_i != 0 -%>
    if [ ! -d "$SCRATCH/.cryosparc_hprc/cache" ]; then
        mkdir -p "$SCRATCH/.cryosparc_hprc/cache"
    fi
    ssdpath="$SCRATCH/.cryosparc_hprc/cache"

    # get 95% of current $SCRATCH quota
    read -r used_quota max_quota <<< $(showquota | grep ^/scratch/user/$USER | tr -s " " | cut -f 2,3 -d " " | sed 's/T//g')
    ssdquota=$( bc <<< "($max_quota - $used_quota) * 0.95 * 100000")
    ssdquota=${ssdquota/.00}
<%- else -%>
    ssdpath="$TMPDIR"
    ssdquota='1400000'
<%- end -%>

# use a max of 5TB for quota
quotamax=5000000
if [ $ssdquota -gt $quotamax ]; then
    echo "quota will use the max of 5TB"
    ssdquota=$quotamax
fi

echo "=== Using ssdpath: $ssdpath"
echo "=== Using ssdquota (MB): $ssdquota"

# Start cryoSPARC Server
echo "=== Starting up cryoSPARC"
set -x

# cryosparcm update --check
# cryosparcw connect --help
# usage: connect.py [-h] [--worker WORKER] [--master MASTER] [--port PORT]
#                  [--sshstr SSHSTR] [--update] [--nogpu] [--gpus GPUS]
#                  [--nossd] [--ssdpath SSDPATH] [--ssdquota SSDQUOTA]
#                  [--ssdreserve SSDRESERVE] [--lane LANE] [--newlane]
#                  [--rams RAMS] [--cpus CPUS] [--monitor_port MONITOR_PORT]

# create symlink from $TMPDIR to /tmp within the image since $TMPDIR full path is used in some parts
singularity exec --nv -B $SCRATCH/.cryosparc_hprc/cryosparc_master/run:/cryosparc_master/run \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_database:/cryosparc_database \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_cache:/cryosparc_cache \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_license:/cryosparc_license \
  -B $TMPDIR:/tmp $group_dir \
  /sw/hprc/sw/ood/apps/cryosparc/$singularity_image ln -s /tmp /tmp/job.$SLURM_JOBID

# start cryosparc
singularity exec --nv -B $SCRATCH/.cryosparc_hprc/cryosparc_master/run:/cryosparc_master/run \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_database:/cryosparc_database \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_cache:/cryosparc_cache \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_license:/cryosparc_license \
  -B $TMPDIR:/tmp $group_dir \
  /sw/hprc/sw/ood/apps/cryosparc/$singularity_image cryosparcm start

# scancel job if cryosparc is already running in another job since it will fail to start
if [ $? != "0" ]; then
   echo "=== cryosparcm start failed. Is cryoSPARC currently running in another job?"
   squeue -u $USER
   scancel $SLURM_JOBID
   exit
fi

# allow cryosparc time to start
sleep 180

# clear previous worker nodes
singularity exec --nv -B $SCRATCH/.cryosparc_hprc/cryosparc_master/run:/cryosparc_master/run \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_database:/cryosparc_database \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_cache:/cryosparc_cache \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_license:/cryosparc_license \
  -B $TMPDIR:/tmp $group_dir \
  /sw/hprc/sw/ood/apps/cryosparc/$singularity_image /opt/remove_hosts.sh

# connect current compute node
singularity exec --nv -B $SCRATCH/.cryosparc_hprc/cryosparc_master/run:/cryosparc_master/run \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_database:/cryosparc_database \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_cache:/cryosparc_cache \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_license:/cryosparc_license \
  -B $TMPDIR:/tmp $group_dir \
  /sw/hprc/sw/ood/apps/cryosparc/$singularity_image cryosparcw connect \
    --worker $nodename \
    --master $nodename \
    --port 39000 \
    --ssdpath $ssdpath \
    --lane default \
    --newlane \
    $usegpu

# update worker node with ssdquota since it doesn't work with the first connection command
singularity exec --nv -B $SCRATCH/.cryosparc_hprc/cryosparc_master/run:/cryosparc_master/run \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_database:/cryosparc_database \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_cache:/cryosparc_cache \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_license:/cryosparc_license \
  -B $TMPDIR:/tmp $group_dir \
  /sw/hprc/sw/ood/apps/cryosparc/$singularity_image cryosparcw connect \
    --worker $nodename \
    --master $nodename \
    --update --ssdquota $ssdquota

# display cryosparc environment variables
singularity exec --nv -B $SCRATCH/.cryosparc_hprc/cryosparc_master/run:/cryosparc_master/run \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_database:/cryosparc_database \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_cache:/cryosparc_cache \
  -B $SCRATCH/.cryosparc_hprc/cryosparc_license:/cryosparc_license \
  -B $TMPDIR:/tmp $group_dir \
  /sw/hprc/sw/ood/apps/cryosparc/$singularity_image cryosparcm env

<%- if context.node_type !~ /CPU/ -%>
  gpustats &
<%- end -%>

# start a terminal only to keep the session alive
xterm
